<?xml version="1.0" encoding="utf-8"?>
<!--
  USB device filter — shows the "Allow access?" prompt when one of these
  devices is plugged in.  Covers the most common USB-serial chips found on
  ESP32 devkits:

    CH340 / CH341  (WCH)           VID 0x1A86
    CP2102 / CP2104 (Silicon Labs)  VID 0x10C4
    FTDI FT232R / FT231X            VID 0x0403
    CDC-ACM generic                 VID 0x03EB, 0x2341 (Atmel/Arduino)
-->
<resources>
    <!-- WCH CH340/CH341 -->
    <usb-device vendor-id="6790" />
    <!-- Silicon Labs CP210x -->
    <usb-device vendor-id="4292" />
    <!-- FTDI -->
    <usb-device vendor-id="1027" />
    <!-- Atmel/Arduino CDC-ACM -->
    <usb-device vendor-id="1003" />
    <usb-device vendor-id="9025" />
</resources>
